# ──────────────────────────────────────────────────────────
#  PetroLedger — Environment Variables (EXAMPLE)
#
#  NEVER commit .env to version control.
#  Copy this file to .env and fill in real values before running.
# ──────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://HOST:6379/0

# ── Auth / JWT ────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=replace-with-a-128-char-random-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Environment (dev | staging | prod) ────────────────────
ENVIRONMENT=dev
APP_VERSION=0.1.0
# Local dev — JSON list format:
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174","http://localhost:5175","http://localhost:5176","http://localhost:5177"]
# Prod — comma-separated string also accepted:
# CORS_ORIGINS=https://your-owner-app.example.com,https://your-manager-app.example.com

# ── Superadmin (required; no defaults) ────────────────────
SUPERADMIN_EMAIL=your-superadmin-email@domain.com
SUPERADMIN_PASSWORD=replace-with-a-strong-password

# ── Frontend URL (used in email links) ────────────────────
FRONTEND_URL=https://app.example.com

# ── AWS / S3 / Textract / SNS ─────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_SNS_REGION=ap-south-1
S3_BUCKET=petroledger-uploads

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ── SMTP / Email ──────────────────────────────────────────
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@petroledger.in
SMTP_FROM_NAME=PetroLedger

# ── Observability ─────────────────────────────────────────
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://HOST:6379/1
